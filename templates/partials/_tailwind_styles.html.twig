{# templates/partials/_tailwind_styles.html.twig #}
<style type="text/tailwindcss">
    @layer base {
        /* Base Form Elements Styling for Symfony Forms */
        input[type="text"], input[type="email"], input[type="password"], input[type="number"], input[type="date"], textarea, select {
            @apply mt-1 block w-full rounded-lg bg-gray-800 border border-gray-700 text-green-400 focus:border-green-500 focus:ring-green-500 placeholder-gray-500 shadow-sm transition-all;
        }
        label {
            @apply block text-sm font-medium text-gray-300 mb-1 mt-4;
        }
    }

    @layer components {
        /* =========================================
           BOTONES
           ========================================= */
        .btn-primario {
            @apply inline-flex items-center justify-center bg-green-600 hover:bg-green-500 text-white font-bold py-2 px-6 rounded-lg shadow-lg shadow-green-600/30 transition-all duration-300 cursor-pointer border border-green-500/50 hover:border-green-400;
        }
        .btn-secundario {
            @apply inline-flex items-center justify-center bg-gray-800 hover:bg-gray-700 text-gray-300 font-medium py-2 px-6 rounded-lg shadow-md transition-all duration-300 cursor-pointer border border-gray-600 hover:border-gray-500 hover:text-white;
        }
        .btn-peligro {
            @apply inline-flex items-center justify-center bg-red-600/90 hover:bg-red-500 text-white text-xs font-bold py-1 px-3 rounded-lg shadow-md transition-all duration-300 border border-red-500/50 hover:shadow-red-500/30;
        }
        .btn-accion {
            @apply inline-flex items-center justify-center bg-gray-700 hover:bg-green-600 text-green-400 hover:text-white text-xs font-bold py-1.5 px-3 rounded-md transition-colors duration-200;
        }

        /* =========================================
           TARJETAS Y CONTENEDORES
           ========================================= */
        .card {
            @apply bg-gray-800/80 backdrop-blur-sm border border-gray-700 rounded-xl shadow-xl p-6 relative overflow-hidden;
        }
        .card-header {
            @apply border-b border-gray-700 pb-4 mb-4 flex justify-between items-center;
        }
        
        /* =========================================
           FORMULARIOS (Custom Classes)
           ========================================= */
        .form-etiqueta {
            @apply block text-sm font-medium text-gray-300 mb-1;
        }
        .form-input {
            @apply mt-1 block w-full rounded-lg bg-gray-800 border border-gray-700 text-green-400 focus:border-green-500 focus:ring-green-500 placeholder-gray-500 shadow-sm transition-all;
        }
        .form-error {
            @apply text-red-400 text-xs mt-1 italic block;
        }
        
        /* =========================================
           BADGES / PASTILLAS
           ========================================= */
        .badge {
            @apply inline-block bg-green-900/50 text-green-400 border border-green-700/50 text-xs px-2.5 py-1 rounded-full font-medium tracking-wide;
        }
        
        /* =========================================
           DATATABLES OVERRIDES
           ========================================= */
        .dt-container {
            @apply text-gray-300;
        }
        .dt-search input {
            @apply form-input py-1.5 px-3 inline-block w-auto ml-2;
        }
        .dt-length select {
            @apply form-input py-1.5 px-8 inline-block w-auto ml-2;
        }
        .dt-paging button {
            @apply hover:bg-gray-700 hover:text-white !important;
        }
        .dt-paging button.current {
            @apply bg-green-600 border-green-600 text-white hover:bg-green-500 !important;
        }
        table.dataTable tbody tr {
            @apply bg-transparent border-gray-700 transition-colors;
        }
        table.dataTable tbody tr:hover {
            @apply bg-gray-700/30;
        }
        table.dataTable th {
            @apply text-green-500 uppercase tracking-wider text-xs font-bold border-b-2 border-gray-700 pb-3;
        }
        table.dataTable td {
            @apply py-4 border-b border-gray-800 text-sm align-middle;
        }
    }
</style>
