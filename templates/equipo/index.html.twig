{% extends 'base.html.twig' %}

{% block title %}{{ 'equipo.index.title'|trans }}{% endblock %}

{% block body %}
    <div class="flex justify-between items-center mb-6">
        <h1 class="page-title">{{ 'equipo.index.title'|trans }}</h1>
        <a href="{{ path('app_equipo_new') }}" class="btn-primario">
            {{ 'equipo.index.new_button'|trans }}
        </a>
    </div>

    <div class="card">
        <table class="datatable min-w-full divide-y divide-gray-700">
            <thead>
                <tr>
                    <th>{{ 'equipo.fields.id'|trans }}</th>
                    <th>{{ 'equipo.fields.nombre'|trans }}</th>
                    <th>{{ 'equipo.fields.codigo_tag'|trans }}</th>
                    <th>{{ 'equipo.fields.fecha_creacion'|trans }}</th>
                    <th>{{ 'equipo.fields.torneos'|trans }}</th>
                    <th class="text-right">{{ 'general.actions'|trans }}</th>
                </tr>
            </thead>
            <tbody>
            {% for equipo in equipos %}
                <tr class="group">
                    <td class="text-gray-400 font-mono">{{ equipo.id }}</td>
                    <td class="font-semibold text-white">{{ equipo.nombre }}</td>
                    <td><span class="text-sm bg-gray-700 text-gray-300 px-2 py-1 rounded font-mono">{{ equipo.codigoTag }}</span></td>
                    <td class="text-gray-400">{{ equipo.fechaCreacion ? equipo.fechaCreacion|date('Y-m-d') : '' }}</td>
                    <td>
                        <div class="flex flex-wrap gap-1">
                        {% for torneo in equipo.torneos %}
                            <span class="badge">{{ torneo.nombre }}</span>
                        {% else %}
                            <span class="text-gray-500 text-sm italic">{{ 'equipo.index.no_tournaments'|trans }}</span>
                        {% endfor %}
                        </div>
                    </td>
                    <td class="text-right space-x-2 opacity-100 md:opacity-0 md:group-hover:opacity-100 transition-opacity">
                        <div class="flex justify-end gap-2">
                            <a href="{{ path('app_equipo_show', {'id': equipo.id}) }}" class="btn-accion">{{ 'general.view'|trans }}</a>
                            <a href="{{ path('app_equipo_edit', {'id': equipo.id}) }}" class="btn-accion">{{ 'general.edit'|trans }}</a>
                            <form method="post" action="{{ path('app_equipo_delete', {'id': equipo.id}) }}" onsubmit="return confirm('{{ 'general.delete_confirm'|trans }}');" class="inline-block">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ equipo.id) }}">
                                <button class="btn-peligro">{{ 'general.delete'|trans }}</button>
                            </form>
                        </div>
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
{% endblock %}
