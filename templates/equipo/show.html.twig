{% extends 'base.html.twig' %}

{% block title %}Equipo: {{ equipo.nombre }}{% endblock %}

{% block body %}
    <div class="mb-6">
        <a href="{{ path('app_equipo_index') }}" class="link-back">
            <span>&larr;</span> {{ 'general.back_to_list'|trans }}
        </a>
    </div>

    <div class="card max-w-3xl mx-auto">
        <div class="card-header">
            <h1 class="text-2xl font-bold text-white">Detalles del Equipo</h1>
            <div class="flex gap-2">
                <a href="{{ path('app_equipo_edit', {'id': equipo.id}) }}" class="btn-secundario py-1.5 px-4 text-sm">{{ 'general.edit'|trans }}</a>
                {{ include('equipo/_delete_form.html.twig') }}
            </div>
        </div>

        <div class="grid-2col">
            <div class="space-y-4">
                <div>
                    <h3 class="label-title">ID</h3>
                    <p class="label-value-mono">{{ equipo.id }}</p>
                </div>
                <div>
                    <h3 class="label-title">{{ 'torneo.fields.nombre'|trans }}</h3>
                    <p class="label-value">{{ equipo.nombre }}</p>
                </div>
                <div>
                    <h3 class="label-title">Código Tag</h3>
                    <p class="label-value"><span class="bg-gray-700 text-gray-200 px-2 py-1 rounded font-mono text-sm">{{ equipo.codigoTag }}</span></p>
                </div>
                <div>
                    <h3 class="label-title">Fecha de Creación</h3>
                    <p class="label-value">{{ equipo.fechaCreacion ? equipo.fechaCreacion|date('d/m/Y') : '-' }}</p>
                </div>
            </div>

            <div class="bg-gray-900/50 rounded-lg p-5 border border-gray-700">
                <h3 class="text-md font-bold text-green-400 mb-4 border-b border-gray-700 pb-2">Torneos Inscritos</h3>
                {% if equipo.torneos is not empty %}
                    <ul class="space-y-2">
                        {% for torneo in equipo.torneos %}
                            <li class="flex items-center gap-2 text-gray-300">
                                <span class="w-1.5 h-1.5 rounded-full bg-green-500"></span>
                                {{ torneo.nombre }}
                            </li>
                        {% endfor %}
                    </ul>
                {% else %}
                    <div class="flex flex-col items-start gap-4">
                        <span class="text-gray-500 text-sm italic">Este equipo no participa en ningún torneo aún.</span>
                        <a href="{{ path('app_torneo_index') }}" class="text-green-500 hover:text-green-400 text-sm font-medium hover:underline">
                            Explorar Torneos &rarr;
                        </a>
                    </div>
                {% endif %}
                
                <h3 class="text-md font-bold text-green-400 mt-8 mb-4 border-b border-gray-700 pb-2">{{ 'equipo.show.players'|trans }}</h3>
                {% if equipo.jugadores is not empty %}
                    <ul class="space-y-3 mb-4">
                        {% for jugador in equipo.jugadores %}
                            <li class="list-item-card">
                                <div>
                                    <span class="text-gray-300 font-medium block">{{ jugador.nickname }}</span>
                                    <span class="text-gray-500 text-xs">{{ jugador.rango.value|trans }}</span>
                                </div>
                                <form method="post" action="{{ path('app_equipo_despedir', {'id': equipo.id, 'jugador_id': jugador.id}) }}" onsubmit="return confirm('{{ 'general.delete_confirm'|trans }}');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('despedir' ~ jugador.id) }}">
                                    <button class="text-red-400 hover:text-red-300 text-sm font-medium">{{ 'equipo.show.fire'|trans }}</button>
                                </form>
                            </li>
                        {% endfor %}
                    </ul>
                {% else %}
                    <div class="text-gray-500 text-sm italic mb-4">
                        {{ 'equipo.show.no_players'|trans }}
                    </div>
                {% endif %}

                <div class="mt-6 pt-4 border-t border-gray-700">
                    <a href="{{ path('app_equipo_fichar', {'id': equipo.id}) }}" class="btn-primario w-full text-sm text-center block">
                        {{ 'equipo.fichar.title'|trans }}
                    </a>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
