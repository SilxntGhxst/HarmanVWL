{% extends 'base.html.twig' %}

{% block title %}Equipo{% endblock %}

{% block body %}
    <h1>Equipo</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ equipo.id }}</td>
            </tr>
            <tr>
                <th>Nombre</th>
                <td>{{ equipo.nombre }}</td>
            </tr>
            <tr>
                <th>Codigo_tag</th>
                <td>{{ equipo.codigoTag }}</td>
            </tr>
            <tr>
                <th>Fecha_creacion</th>
                <td>{{ equipo.fechaCreacion ? equipo.fechaCreacion|date('Y-m-d') : '' }}</td>
            </tr>
            <tr>
                <th>Torneos Inscritos</th>
                <td>
                    {% if equipo.torneos is not empty %}
                        <ul class="list-disc list-inside text-gray-300">
                            {% for torneo in equipo.torneos %}
                                <li>{{ torneo.nombre }}</li>
                            {% endfor %}
                        </ul>
                    {% else %}
                        {# Contenedor flex para alinear el texto y el botón #}
                        <div class="flex items-center gap-4">
                            <span class="text-gray-500 italic">Este equipo no participa en ningún torneo aún.</span>

                            {# Redirige a la lista general de torneos #}
                            <a href="{{ path('app_torneo_index') }}" class="bg-indigo-600 hover:bg-indigo-700 text-white text-xs font-bold py-1 px-3 rounded transition-colors">
                                Explorar Torneos
                            </a>
                        </div>
                    {% endif %}
                </td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_equipo_index') }}">back to list</a>

    <a href="{{ path('app_equipo_edit', {'id': equipo.id}) }}">edit</a>

    <a href="{{ path('app_equipo_fichar', {'id': equipo.id}) }}" class="inline-block bg-green-600 hover:bg-green-700 text-white font-bold py-2 px-4 rounded transition-colors">
        Fichar Jugador
    </a>

    {{ include('equipo/_delete_form.html.twig') }}
{% endblock %}
