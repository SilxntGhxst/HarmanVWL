{% extends 'base.html.twig' %}

{% block title %}Jugador: {{ jugador.nickname }}{% endblock %}

{% block body %}
    <div class="mb-6">
        <a href="{{ path('app_jugador_index') }}" class="link-back">
            <span>&larr;</span> {{ 'general.back_to_list'|trans }}
        </a>
    </div>

    <div class="card max-w-3xl mx-auto">
        <div class="card-header">
            <h1 class="text-2xl font-bold text-white">{{ 'jugador.show.profile'|trans }}</h1>
            <div class="flex gap-2">
                <a href="{{ path('app_jugador_edit', {'id': jugador.id}) }}" class="btn-secundario py-1.5 px-4 text-sm">{{ 'general.edit'|trans }}</a>
                {{ include('jugador/_delete_form.html.twig') }}
            </div>
        </div>

        <div class="grid-2col">
            <div class="space-y-4">
                <div>
                    <h3 class="label-title">ID</h3>
                    <p class="label-value-mono">{{ jugador.id }}</p>
                </div>
                <div>
                    <h3 class="label-title">{{ 'jugador.fields.nickname'|trans }}</h3>
                    <p class="label-value">{{ jugador.nickname }}</p>
                </div>
                <div>
                    <h3 class="label-title">{{ 'jugador.fields.email'|trans }}</h3>
                    <p class="label-value">{{ jugador.email }}</p>
                </div>
                <div class="flex gap-6">
                    <div>
                        <h3 class="label-title">{{ 'jugador.fields.edad'|trans }}</h3>
                        <p class="label-value">{{ jugador.edad }}</p>
                    </div>
                    <div>
                        <h3 class="label-title">{{ 'jugador.fields.rango'|trans }}</h3>
                        <p class="mt-1 text-lg">
                            {% if jugador.rango %}
                                <span class="badge">{{ jugador.rango.value|trans }}</span>
                            {% else %}
                                -
                            {% endif %}
                        </p>
                    </div>
                </div>
            </div>

            <div class="bg-gray-900/50 rounded-lg p-5 border border-gray-700">
                <h3 class="text-md font-bold text-green-400 mb-4 border-b border-gray-700 pb-2">{{ 'jugador.show.current_status'|trans }}</h3>
                {% if jugador.equipo %}
                    <div class="flex flex-col items-start gap-4">
                        <div class="flex items-center gap-2">
                            <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
                            <span class="text-white font-medium">{{ 'jugador.show.signed_by'|trans }}: <span class="text-green-400">{{ jugador.equipo.nombre }}</span></span>
                        </div>
                        <a href="{{ path('app_jugador_liberar', {'id': jugador.id}) }}" class="btn-peligro w-full mt-4" onclick="return confirm('{{ 'jugador.show.release_confirm'|trans }}');">
                            {{ 'jugador.show.release'|trans }}
                        </a>
                    </div>
                {% else %}
                    <div class="flex flex-col items-start gap-4">
                        <div class="flex items-center gap-2">
                            <span class="w-2 h-2 rounded-full bg-gray-500"></span>
                            <span class="text-gray-400 italic">{{ 'jugador.free_agent'|trans }}</span>
                        </div>
                        <a href="{{ path('app_equipo_index') }}" class="btn-primario w-full mt-4 text-sm">
                            {{ 'jugador.show.view_teams'|trans }}
                        </a>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
{% endblock %}
