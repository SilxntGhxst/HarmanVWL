{% extends 'base.html.twig' %}

{% block title %}Torneos{% endblock %}

{% block body %}
    <div class="flex justify-between items-center mb-6">
        <h1 class="text-3xl font-bold text-white tracking-tight">Torneos</h1>
        <a href="{{ path('app_torneo_new') }}" class="btn-primario">
            + Nuevo Torneo
        </a>
    </div>

    <div class="card">
        <table id="tablaTorneos" class="min-w-full divide-y divide-gray-700">
            <thead>
                <tr>
                    <th>Id</th>
                    <th>Nombre</th>
                    <th>Juego</th>
                    <th>Bolsa Premios</th>
                    <th>Estado</th>
                    <th class="text-right">Acciones</th>
                </tr>
            </thead>
            <tbody>
            {% for torneo in torneos %}
                <tr class="group">
                    <td class="text-gray-400 font-mono">{{ torneo.id }}</td>
                    <td class="font-semibold text-white">{{ torneo.nombre }}</td>
                    <td class="text-gray-400">{{ torneo.juego }}</td>
                    <td class="text-green-400 font-mono">${{ torneo.bolsaPremios|number_format(2, '.', ',') }}</td>
                    <td>
                        {% if torneo.estado %}
                            <span class="badge bg-green-900/40 border-green-500/30 text-green-300">{{ torneo.estado.value }}</span>
                        {% endif %}
                    </td>
                    <td class="text-right space-x-2 opacity-100 md:opacity-0 md:group-hover:opacity-100 transition-opacity">
                        <a href="{{ path('app_torneo_show', {'id': torneo.id}) }}" class="btn-accion">Ver</a>
                        <a href="{{ path('app_torneo_edit', {'id': torneo.id}) }}" class="btn-accion">Editar</a>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="6" class="text-center text-gray-500 py-8">No se encontraron torneos</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>

    {% block javascripts_locales %}
        <script>
            document.addEventListener("turbo:load", function() {
                let tabla = $('#tablaTorneos');

                if (tabla.length) {
                    if (!$.fn.DataTable.isDataTable(tabla)) {
                        tabla.DataTable({
                            language: {
                                url: 'https://cdn.datatables.net/plug-ins/2.0.8/i18n/es-MX.json',
                            },
                            columnDefs: [
                                {
                                    "targets": [-1],
                                    "orderable": false
                                }
                            ]
                        });
                    }
                }
            });
        </script>
    {% endblock %}

{% endblock %}
