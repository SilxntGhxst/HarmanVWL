<!DOCTYPE html>
<html lang="{{ app.request.locale }}" class="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Gestión de Esports | HarmanVWL{% endblock %}</title>

    {# Google Fonts: Inter #}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    {# Webpack Encore Assets #}
    {% block stylesheets %}
        {{ encore_entry_link_tags('app') }}
    {% endblock %}

    {% block javascripts %}
        {{ encore_entry_script_tags('app') }}
    {% endblock %}
</head>
<body class="bg-gray-900 text-gray-300 min-h-screen flex flex-col font-sans selection:bg-green-500/30 selection:text-green-200">

    {# Navbar Moderna #}
    <nav class="bg-gray-900/80 backdrop-blur-md border-b border-gray-800 sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex items-center justify-between h-16">
                <div class="flex-shrink-0 flex items-center gap-2">
                    <div class="w-8 h-8 rounded bg-gradient-to-br from-green-400 to-green-600 flex items-center justify-center shadow-lg shadow-green-500/20">
                        <span class="text-white font-bold text-xl">H</span>
                    </div>
                    <a href="{{ path('app_home') }}" class="text-xl font-bold text-white tracking-tight">Harman<span class="text-green-500">VWL</span></a>
                </div>
                <div class="hidden md:flex flex-1 justify-between items-center ml-10">
                    <div class="flex items-baseline space-x-1">
                        <a href="{{ path('app_home') }}" class="text-gray-300 hover:text-green-400 hover:bg-gray-800 px-3 py-2 rounded-md text-sm font-medium transition-colors">{{ 'nav.home'|trans }}</a>
                        <a href="{{ path('app_equipo_index') }}" class="text-gray-300 hover:text-green-400 hover:bg-gray-800 px-3 py-2 rounded-md text-sm font-medium transition-colors">{{ 'nav.teams'|trans }}</a>
                        <a href="{{ path('app_jugador_index') }}" class="text-gray-300 hover:text-green-400 hover:bg-gray-800 px-3 py-2 rounded-md text-sm font-medium transition-colors">{{ 'nav.players'|trans }}</a>
                        <a href="{{ path('app_torneo_index') }}" class="text-gray-300 hover:text-green-400 hover:bg-gray-800 px-3 py-2 rounded-md text-sm font-medium transition-colors">{{ 'nav.tournaments'|trans }}</a>
                    </div>
                    
                    <div class="flex items-center ml-4 space-x-2 border-l border-gray-700 pl-4">
                        <a href="{{ path('app_switch_locale', {'_locale': 'es'}) }}" class="px-2 py-1 text-xs font-semibold rounded {{ app.request.locale == 'es' ? 'bg-green-600 text-white' : 'text-gray-400 hover:bg-gray-800 hover:text-gray-200' }}">ES</a>
                        <a href="{{ path('app_switch_locale', {'_locale': 'en'}) }}" class="px-2 py-1 text-xs font-semibold rounded {{ app.request.locale == 'en' ? 'bg-green-600 text-white' : 'text-gray-400 hover:bg-gray-800 hover:text-gray-200' }}">EN</a>
                    </div>
                </div>
            </div>
        </div>
    </nav>

    {# Contenido Principal #}
    <main class="flex-grow w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        {% block body %}{% endblock %}
    </main>

    {# Footer #}
    <footer class="bg-gray-900 border-t border-gray-800 py-6 mt-auto">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center text-sm text-gray-500">
            &copy; {{ "now"|date("Y") }} {{ 'footer.rights'|trans }}
        </div>
    </footer>

</body>
</html>
