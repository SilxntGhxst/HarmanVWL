<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>{% block title %}Harman VWL{% endblock %}</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">

    {# 1. Inyección de Tailwind CSS por CDN para los estilos #}
    <script src="https://cdn.tailwindcss.com"></script>

    {# 2. Inyección de Hotwire Turbo por CDN para la navegación fluida (SPA) #}
    <script type="module">
        import * as Turbo from 'https://cdn.jsdelivr.net/npm/@hotwired/turbo@8.0.4/+esm';
    </script>

    <link rel="stylesheet" href="https://cdn.datatables.net/2.0.8/css/dataTables.tailwindcss.css">

    {% block stylesheets %}
    {% endblock %}

    {% block javascripts %}
        {# Mantenemos el importmap apagado para evitar cualquier conflicto con archivos locales #}
        {# {% block importmap %}{{ importmap('app') }}{% endblock %} #}
    {% endblock %}
</head>
<body class="bg-gray-900 text-green-500 min-h-screen">
<nav>
    <ul>
        {# Enlace usando el nombre de la ruta (route) configurada en tu controlador #}
        <li><a href="{{ path('app_home') }}">Inicio</a></li>
        <li><a href="{{ path('app_equipo_index') }}">Equipos</a></li>
        <li><a href="{{ path('app_jugador_index') }}">Jugadores</a></li>
        <li><a href="{{ path('app_torneo_index') }}">Torneos</a></li>
    </ul>
</nav>
{% block body %}{% endblock %}

<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script src="https://cdn.datatables.net/2.0.8/js/dataTables.js"></script>
<script src="https://cdn.datatables.net/2.0.8/js/dataTables.tailwindcss.js"></script>

{# Aquí abrimos un bloque de Twig para que las páginas hijas puedan inyectar su propio JS #}
{% block javascripts_locales %}{% endblock %}

</body>
</html>
